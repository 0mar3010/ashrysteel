---
const projects = [
  {
    name: 'Suez Canal tunnels',
    note: 'Rebar and structural sections for one of Egypt’s largest infrastructure projects of the last decade.',
  },
  {
    name: 'New Administrative Capital',
    note: 'Structural steel and reinforcement supplied across multiple phases of Egypt’s new capital district.',
  },
  {
    name: 'Damietta Port',
    note: 'Marine and structural steel for port infrastructure expansion.',
  },
  {
    name: '"Hayah Karima" national development program',
    note: '15,000+ lighting poles supplied to Egypt’s national rural development initiative.',
  },
];
---

<section id="field-record" class="field-record section-pad">
  <div class="container">
    <h2 class="field-record__heading">Built with our steel.</h2>

    <ul class="field-record__list">
      {projects.map((p) => (
        <li class="field-record__item">
          <span class="field-record__name">{p.name}</span>
          <span class="field-record__note">{p.note}</span>
        </li>
      ))}
    </ul>

    <a href="#contact" class="field-record__link">
      Request a quote for your project
      <svg width="16" height="10" viewBox="0 0 16 10" fill="none" aria-hidden="true">
        <path d="M0.5 5H15M15 5L10.5 0.5M15 5L10.5 9.5" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .field-record {
    background: var(--color-charcoal);
    color: var(--color-ink-on-dark);
  }

  .field-record__heading {
    font-size: var(--text-display-sm);
    color: var(--color-ink-on-dark);
    margin-bottom: var(--space-2xl);
    max-width: 20ch;
  }

  .field-record__list {
    list-style: none;
    margin: 0 0 var(--space-2xl);
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .field-record__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding-block: var(--space-lg);
    border-bottom: 1px solid var(--color-border-on-dark);
  }

  .field-record__item:first-child {
    border-top: 1px solid var(--color-border-on-dark);
  }

  .field-record__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xl);
    color: var(--color-ink-on-dark);
  }

  .field-record__note {
    color: var(--color-ink-on-dark-dim);
    font-size: var(--text-sm);
    max-width: 56ch;
  }

  .field-record__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-blue-on-dark);
    text-decoration: none;
    font-weight: 600;
  }

  .field-record__link svg {
    transition: transform var(--duration-state) var(--ease-out-quart);
  }

  .field-record__link:hover svg,
  .field-record__link:focus-visible svg {
    transform: translateX(4px);
  }

  @media (min-width: 900px) {
    .field-record__item {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-2xl);
    }

    .field-record__name {
      flex: 0 0 auto;
      width: 34%;
    }
  }
</style>
