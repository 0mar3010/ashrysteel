---
const productOptions = [
  'Rebar & Sections',
  'Pipes & Flat Steel',
  'Fabricated & Structural',
  'Special Steel (Arcosteel)',
  'Not sure yet',
];
---

<section id="contact" class="quote section-pad">
  <div class="container quote__layout">
    <div class="quote__intro reveal">
      <h2 class="section-heading">Tell us what you're building.</h2>
      <p class="lead section-lead">
        Share your project's scope and our sales team will follow up with pricing,
        lead times, and mill certification documents for your product of interest.
      </p>
      <dl class="quote__contact">
        <div>
          <dt>Phone</dt>
          <dd><a href="tel:+201024999929">+20 10 2499 9929</a></dd>
        </div>
        <div>
          <dt>Email</dt>
          <dd><a href="mailto:info@elashrygroup.com">info@elashrygroup.com</a></dd>
        </div>
        <div>
          <dt>Headquarters</dt>
          <dd>5 Mohamed Thaqeb St, Zamalek, Cairo, Egypt</dd>
        </div>
      </dl>
    </div>

    <form class="quote-form reveal" id="quote-form" novalidate>
      <div class="quote-form__row">
        <div class="field">
          <label for="qf-name">Full name</label>
          <input type="text" id="qf-name" name="name" required autocomplete="name" aria-describedby="qf-name-err" />
          <p class="field__error" id="qf-name-err" role="alert"></p>
        </div>
        <div class="field">
          <label for="qf-company">Company</label>
          <input type="text" id="qf-company" name="company" required autocomplete="organization" aria-describedby="qf-company-err" />
          <p class="field__error" id="qf-company-err" role="alert"></p>
        </div>
      </div>

      <div class="quote-form__row">
        <div class="field">
          <label for="qf-email">Email address</label>
          <input type="email" id="qf-email" name="email" required autocomplete="email" aria-describedby="qf-email-err" />
          <p class="field__error" id="qf-email-err" role="alert"></p>
        </div>
        <div class="field">
          <label for="qf-phone">Phone number</label>
          <input type="tel" id="qf-phone" name="phone" autocomplete="tel" aria-describedby="qf-phone-err" />
          <p class="field__error" id="qf-phone-err" role="alert"></p>
        </div>
      </div>

      <div class="field">
        <label for="qf-product">Product of interest</label>
        <select id="qf-product" name="product" required aria-describedby="qf-product-err">
          <option value="" selected disabled>Choose a product line</option>
          {productOptions.map((opt) => <option value={opt}>{opt}</option>)}
        </select>
        <p class="field__error" id="qf-product-err" role="alert"></p>
      </div>

      <div class="field">
        <label for="qf-message">Project details</label>
        <textarea id="qf-message" name="message" rows="4" placeholder="Grades, quantities, delivery timeline…" aria-describedby="qf-message-err" required></textarea>
        <p class="field__error" id="qf-message-err" role="alert"></p>
      </div>

      <button type="submit" class="btn btn--primary quote-form__submit">
        <span class="quote-form__submit-label">Send request</span>
        <span class="quote-form__spinner" aria-hidden="true"></span>
      </button>

      <p class="quote-form__status" id="qf-status" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  const status = document.getElementById('qf-status');

  const validators: Record<string, (value: string) => string | null> = {
    name: (v) => (v.trim().length < 2 ? 'Please enter your full name.' : null),
    company: (v) => (v.trim().length < 2 ? 'Please enter your company name.' : null),
    email: (v) => (/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? null : 'Enter a valid email, like name@company.com.'),
    product: (v) => (v === '' ? 'Choose a product line, or select "Not sure yet".' : null),
    message: (v) => (v.trim().length < 10 ? 'Add a few more details so sales can quote accurately.' : null),
  };

  function fieldEl(name: string) {
    return form?.querySelector<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(`[name="${name}"]`) ?? null;
  }

  function validateField(name: string): boolean {
    const el = fieldEl(name);
    const validator = validators[name];
    if (!el || !validator) return true;
    const errorEl = document.getElementById(`qf-${name}-err`);
    const message = validator(el.value);
    if (message) {
      el.setAttribute('aria-invalid', 'true');
      if (errorEl) errorEl.textContent = message;
      return false;
    }
    el.removeAttribute('aria-invalid');
    if (errorEl) errorEl.textContent = '';
    return true;
  }

  Object.keys(validators).forEach((name) => {
    const el = fieldEl(name);
    el?.addEventListener('blur', () => validateField(name));
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const results = Object.keys(validators).map(validateField);
    if (results.some((ok) => !ok)) {
      if (status) status.textContent = 'Please fix the highlighted fields before sending.';
      form.querySelector<HTMLElement>('[aria-invalid="true"]')?.focus();
      return;
    }

    form.classList.add('is-submitting');
    if (status) status.textContent = 'Sending your request…';

    await new Promise((resolve) => setTimeout(resolve, 1200));

    form.classList.remove('is-submitting');
    form.classList.add('is-success');
    if (status) status.textContent = 'Request sent. Our sales team will reach out within one business day.';
    form.reset();
  });
</script>

<style>
  .quote__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  .quote__intro {
    max-width: 34rem;
  }

  .quote__intro h2 {
    margin-block: var(--space-sm) var(--space-md);
  }

  .quote__contact {
    margin-top: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .quote__contact dt {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-faint);
  }

  .quote__contact dd {
    margin: 0;
    font-size: var(--text-base);
  }

  .quote__contact a {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-strong);
  }

  .quote__contact a:hover,
  .quote__contact a:focus-visible {
    border-color: var(--color-blue);
    color: var(--color-blue);
  }

  .quote-form {
    background: var(--color-white);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .quote-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .field label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
  }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-body);
    font-size: var(--text-base);
    background: var(--color-white);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    color: var(--color-ink);
    padding: var(--space-sm) var(--space-md);
    min-height: 44px;
    transition: border-color var(--duration-state) var(--ease-out-quart);
  }

  .field textarea {
    resize: vertical;
    min-height: 96px;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--color-ink-faint);
    opacity: 1;
  }

  .field input:focus-visible,
  .field select:focus-visible,
  .field textarea:focus-visible {
    outline: none;
    border-color: var(--color-blue);
    box-shadow: 0 0 0 1px var(--color-blue);
  }

  .field input[aria-invalid='true'],
  .field textarea[aria-invalid='true'] {
    border-color: var(--color-error);
  }

  .field__error {
    margin: 0;
    min-height: 1.2em;
    font-size: var(--text-xs);
    color: var(--color-error);
  }

  .quote-form__submit {
    align-self: flex-start;
    position: relative;
  }

  .quote-form__spinner {
    display: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid color-mix(in oklch, var(--color-white) 35%, transparent);
    border-top-color: var(--color-white);
  }

  .quote-form.is-submitting .quote-form__submit {
    pointer-events: none;
    opacity: 0.85;
  }

  .quote-form.is-submitting .quote-form__spinner {
    display: inline-block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .quote-form.is-submitting .quote-form__spinner {
      animation: spin 700ms linear infinite;
    }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .quote-form__status {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-ink-dim);
    min-height: 1.2em;
  }

  .quote-form.is-success .quote-form__status {
    color: var(--color-success);
  }

  @media (min-width: 640px) {
    .quote-form__row {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1000px) {
    .quote__layout {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--space-3xl);
    }
  }
</style>
